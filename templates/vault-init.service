[Unit]
Description=Initialize Vault
After=vault.service
Requires=vault.service

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=ENROLL_ADDR=127.0.0.1:8443
Environment=ENROLL_CACERT=/etc/pigeon/identity/ca.pem
Environment=ENROLL_IDENTITY_DIR=/etc/pigeon/identity
ExecStart=/usr/local/bin/vault-init

[Install]
WantedBy=multi-user.target
