[Unit]
Description=pigeon-mesh WireGuard overlay
After=network-online.target
Wants=network-online.target
ConditionPathExists=/etc/pigeon/mesh.json
ConditionPathExists=/etc/credstore.encrypted/pigeon-mesh.gossip-key
ConditionPathExists=/etc/credstore.encrypted/pigeon-mesh.wg-key

[Service]
Type=notify
ExecStart=/opt/pigeon/bin/pigeon-mesh \
  --config=/etc/pigeon/mesh.json \
  --gossip-key-path=%d/gossip-key \
  --wg-key-path=%d/wg-key
LoadCredentialEncrypted=gossip-key:/etc/credstore.encrypted/pigeon-mesh.gossip-key
LoadCredentialEncrypted=wg-key:/etc/credstore.encrypted/pigeon-mesh.wg-key
Restart=on-failure
RestartSec=5
WatchdogSec=30s

NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/lib/pigeon-mesh /run/pigeon-mesh
ReadOnlyPaths=/etc/pigeon
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW
LimitCORE=0

[Install]
WantedBy=multi-user.target
