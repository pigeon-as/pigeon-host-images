[Unit]
Description=Vault Agent (Nomad TLS cert renewal from Vault PKI)
Wants=network-online.target
After=network-online.target pigeon-mesh.service consul.service
Requires=pigeon-mesh.service consul.service
ConditionPathExists=/encrypted/tls/auth/cert.pem
ConditionPathExists=/encrypted/tls/auth/key.pem

[Service]
ExecStart=/usr/bin/vault agent -config=/etc/pigeon/vault-agent.hcl
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
LimitCORE=0
NoNewPrivileges=yes
ProtectSystem=full
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes

[Install]
WantedBy=multi-user.target
